<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>SkyRoute_Travel_Platform_BackEnd</RootNamespace>
        <DefaultItemExcludes>$(DefaultItemExcludes);TestProject\**;TestProject1\**;SkyRoute.Tests\**</DefaultItemExcludes> 
<!--        We ignore the config files generated by the test projects to prevent them from being included in the main 
project build and causing potential conflicts or issues. -->
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.5" />
        <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="8.0.0" />
        <PackageReference Include="Moq" Version="4.20.72" />
        <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
        <PackageReference Include="Swashbuckle.AspNetCore.Annotations" Version="10.1.7" />
        <PackageReference Include="xunit.assert" Version="2.9.3" />
        <PackageReference Include="xunit.extensibility.core" Version="2.9.3" />
        
    </ItemGroup>

    <ItemGroup>
      <_ContentIncludedByDefault Remove="SkyRoute.Tests\obj\project.assets.json" />
      <_ContentIncludedByDefault Remove="SkyRoute.Tests\obj\project.packagespec.json" />
      <_ContentIncludedByDefault Remove="SkyRoute.Tests\obj\SkyRoute.Tests.csproj.nuget.dgspec.json" />
      <_ContentIncludedByDefault Remove="TestProject\obj\project.assets.json" />
      <_ContentIncludedByDefault Remove="TestProject\obj\project.packagespec.json" />
      <_ContentIncludedByDefault Remove="TestProject\obj\TestProject.csproj.nuget.dgspec.json" />
    </ItemGroup>

</Project>
